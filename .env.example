# Copy this file to .env and fill in what you need. `.env` is gitignored —
# it holds your API key and live pod data, and must NEVER be committed.
#
#   cp .env.example .env
#
# ---------------------------------------------------------------- required

# RunPod API key (console.runpod.io -> Settings -> API Keys).
# Needed by up.py / down.py / deploy_pod.py / terminate_pod.py.
RUNPOD_API_KEY=

# ------------------------------------------- written automatically by up.py
# You normally never edit these: deploy records them at pod-creation time.
# They are listed here so you know what lands in your .env.

# POD_ID=
# POD_NAME=
# POD_GPU_TYPE=
# POD_IMAGE=
# POD_RATE_USD_HR=
# POD_SSH_CMD=

# -------------------------------------------------- benchmark overrides
# scripts/llm_bench reads these; the defaults target the local relay, so you
# only set them to point the same benchmark at another backend (Ollama,
# OpenRouter, ...) — that portability is the point of the experiment.

# LLM_BASE_URL=http://localhost:8080/v1
# LLM_API_KEY=not-needed
# LLM_MODEL=gpt-oss-20b
